@model Reactivities.MVC.Models.ActivityViewModel

<div class="col">
    <div class="">
        <div class="col-md-8">
            <div class="card h-100">
                <img itemid="@Model.Id" src="../Images/categoryImages/(@Html.DisplayFor(x=>x.Category)).jpg> class="card-img-top" alt="...">
                <div class="card-body">
                    <h5 class="card-title"></h5>
                    <small itemid="@Model.Id" class="card-text">@Html.Encode(Model.Date)</small>
                    <p itemid="@Model.Id" class="card-text">@Html.Encode(Model.Description)</p>
                </div>
                <div class="card-footer">
                    <div class="btn-group" role="group" aria-label="Basic checkbox toggle button group">
                        <input type="checkbox" class="btn-check" id="btncheck1" autocomplete="off">
                        <label class="btn btn-outline-primary" for="btncheck1">@Html.ActionLink("Edit", "Edit", new { /* id = Model.PrimaryKey */ }) </label>

                        <input type="checkbox" class="btn-check" id="btncheck2" autocomplete="off">
                        <label asp-action="Index" class="btn btn-outline-secondary" for="btncheck2"><a asp-action="Index">Cancel</a></label>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
