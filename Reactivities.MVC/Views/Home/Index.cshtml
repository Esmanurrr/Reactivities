@model List<ActivityViewModel>
@{
    ViewData["Title"] = "Home Page";
}

<div class="container">
    <div class="row">
        <div class="col-md-7">
            <div style="position: relative;">
                <ul class="list-group">
                    @foreach (var i in Model)
                    {
                        <a href="#" class="list-group-item list-group-item-action" >
                            <div class="d-flex w-100 justify-content-between">
                                <h5 class="mb-1" name="@i.Id">@Html.DisplayFor(modelItem => i.Title)</h5>
                            </div>
                            <p class="text-body-secondary">@Html.DisplayFor(modelItem => i.Date)</p>
                            <p class="mb-1">@Html.DisplayFor(modelItem => i.Description)</p>
                            <small class="text-body-secondary">@Html.DisplayFor(modelItem => i.City), @Html.DisplayFor(modelItem => i.Venue)</small>
                            <div>
                                <label id="categoryLabel">@Html.DisplayFor(modelItem => i.Category)</label>
                                <input type="submit" value="View" onclick="redirectToDetails('@i.Id')" style="position: absolute; bottom: 10px; right: 10px;" class="btn btn-primary" />
                                @* <input value="Submit" type="submit" class="btn btn-primary" /> *@
                            </div>
                        </a>
                    }
                </ul>
            </div>
        </div>
         
    </div>
</div>

<script>
    function redirectToDetails(id) {
        // JavaScript kullanarak yönlendirme yap
        window.location.href = '/Home/Details/' + id; // ControllerName'i kendi kontrolcü adınızla değiştirin
    }
</script>

